{
  "name": "plan2net/webp",
  "license": "GPL-3.0-or-later",
  "description": "Drop-in WebP delivery for TYPO3 images — automatic, no URL or template changes",
  "type": "typo3-cms-extension",
  "homepage": "https://www.plan2.net/",
  "authors": [
    {
      "name": "Wolfgang Klinger",
      "role": "Lead Developer"
    },
    {
      "name": "Martin Kutschker",
      "role": "reStructuredText Documentation"
    },
    {
      "name": "Team Wonderland",
      "role": "Support and review"
    }
  ],
  "config": {
    "vendor-dir": ".Build/vendor",
    "bin-dir": ".Build/bin",
    "sort-packages": true,
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  },
  "require": {
    "php": ">=8.2",
    "symfony/finder": "^6.4 || ^7.0",
    "typo3/cms-core": "^12.4 || ^13.4 || ^14.0"
  },
  "suggest": {
    "ext-gd": "Use GD for image processing",
    "typo3/cms-install": "Required only if you run the UpgradeWizard that clears legacy tx_webp_failed rows during a configuration_hash column resize",
    "typo3/cms-scheduler": "Required only when async = 1; provides the scheduler task that drains tx_webp_queue out-of-band"
  },
  "autoload": {
    "psr-4": {
      "Plan2net\\Webp\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Plan2net\\Webp\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "webp",
      "version": "14.1.1",
      "cms-package-dir": "{$vendor-dir}/typo3/cms",
      "web-dir": ".Build/Web",
      "Package": {
        "providesPackages": {}
      }
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11",
    "typo3/cms-install": "^12.4 || ^13.4 || ^14.0",
    "typo3/cms-scheduler": "^12.4 || ^13.4 || ^14.0",
    "typo3/testing-framework": "^8.0 || ^9.0",
    "friendsofphp/php-cs-fixer": "^3.75"
  }
}
