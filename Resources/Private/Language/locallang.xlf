        <source>Process conversion queue</source>
      </trans-unit>
      <trans-unit id="task.processQueue.description">
        <source>Drains pending tx_webp_queue entries created by the AfterFileProcessing listener when async = 1.</source>
      </trans-unit>
      <trans-unit id="task.processQueue.batchSize.label">
        <source>Batch size (entries per run)</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode">
