<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" datatype="plaintext" original="EXT:webp/Resources/Private/Language/locallang.xlf" product-name="webp">
    <header/>
    <body>
      <trans-unit id="task.processQueue.title">
        <source>Process conversion queue</source>
      </trans-unit>
      <trans-unit id="task.processQueue.description">
        <source>Drains pending tx_webp_queue entries created by the AfterFileProcessing listener when async = 1.</source>
      </trans-unit>
      <trans-unit id="task.processQueue.batchSize.label">
        <source>Batch size (entries per run)</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode">
        <source>Generate WebP / AVIF / JPEG XL siblings</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.description">
        <source>When enabled, processed images on this storage get sibling files at the same path — one per enabled output format — for transparent delivery via Accept-header content negotiation. The active formats are configured via the formats_enabled extension setting.</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.auto">
        <source>Auto (Local drivers only)</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.enabled">
        <source>Enabled</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.disabled">
        <source>Disabled</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_quality">
        <source>Compression quality</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_quality.description">
        <source>Overrides the global compression quality for this image only (1–100, lower = stronger compression and smaller file). Applies to all enabled output formats. Leave at 0 to use the global extension setting.</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_compression_report">
        <source>Compression results</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_compression_report.empty">
        <source>No optimized versions generated yet — render a page that uses this image, then reopen.</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_compression_report.source">
        <source>Source</source>
      </trans-unit>
      <trans-unit id="sys_file_metadata.tx_webp_compression_report.missing">
        <source>No %s version generated for this variant.</source>
      </trans-unit>
    </body>
  </file>
</xliff>
