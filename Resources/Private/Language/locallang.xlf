      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.description">
        <source>When enabled, processed images on this storage get sibling files at the same path — one per enabled output format — for transparent delivery via Accept-header content negotiation. The active formats are configured via the formats_enabled extension setting.</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.auto">
        <source>Auto (Local drivers only)</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.enabled">
        <source>Enabled</source>
      </trans-unit>
      <trans-unit id="sys_file_storage.tx_webp_mode.disabled">
        <source>Disabled</source>
      </trans-unit>
